# Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uaskte_db
DB_USER=root
DB_PASS=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost/uaskte/public/callback.php

# Fonnte WhatsApp API
FONNTE_TOKEN=your-fonnte-token-here

# App Settings
APP_NAME="UASKTE App"
APP_URL=http://localhost/uaskte/public
APP_DEBUG=true
